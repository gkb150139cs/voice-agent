# --- Runtime ---
APP_NAME=voice-attribute-service
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# --- Inference ---
# stub: deterministic lightweight path (CI / smoke)
# local: load HF weights inside this process
# worker: API stays stateless; pair with USE_INFERENCE_WORKER=true + arq worker service
INFERENCE_MODE=local
MODEL_ID=audeering/wav2vec2-large-robust-24-ft-age-gender
TORCH_DEVICE=cpu

# Offload inference to Redis queue workers (see docker-compose `worker` service)
USE_INFERENCE_WORKER=false
REDIS_URL=redis://localhost:6379/0
INFERENCE_JOB_TIMEOUT_S=120

# --- Audio preprocessing ---
TARGET_SAMPLE_RATE=16000
MIN_SPEECH_SECONDS=0.4
DEGRADED_SNR_DB=8.0
CLIPPING_RATIO_THRESHOLD=0.002

# --- Ops / privacy ---
MAX_UPLOAD_BYTES=5000000
REQUEST_ID_HEADER=X-Request-ID

# Silero VAD (torch hub). Set false in constrained CI or air-gapped environments.
USE_SILERO_VAD=true

# Optional bonus field (currently returns nulls unless you extend the pipeline)
ENABLE_LANG_FIELD=false

# Hugging Face cache (Dockerfile sets defaults under /cache)
# HF_HOME=/cache/huggingface
# TRANSFORMERS_CACHE=/cache/huggingface
